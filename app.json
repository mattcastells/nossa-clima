{
  "expo": {
    "name": "Nossa Clima",
    "slug": "nossa-clima",
    "version": "0.4.0",
    "orientation": "portrait",
    "scheme": "nossaclima",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.nossaclima.app",
      "versionCode": 12,
      "permissions": [
        "RECORD_AUDIO",
        "REQUEST_INSTALL_PACKAGES",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#052653"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Permiti que Nossa Clima use el microfono para enviar audios al asistente."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#052653",
          "sounds": []
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/MaterialCommunityIcons.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
