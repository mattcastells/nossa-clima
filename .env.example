# Supabase project URL (Dashboard > Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key (Dashboard > Settings > API)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional override for the public GitHub repo used for APK releases
EXPO_PUBLIC_APP_UPDATE_GITHUB_REPO=mattcastells/nossa-clima
