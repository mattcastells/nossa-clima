{
  "expo": {
    "name": "Nossa Clima",
    "slug": "nossa-clima",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "nossaclima",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.nossaclima.app",
      "versionCode": 1,
      "permissions": [
        "REQUEST_INSTALL_PACKAGES"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#052653"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
